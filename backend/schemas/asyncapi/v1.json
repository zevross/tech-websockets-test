{
  "asyncapi": "3.0.0",
  "info": {
    "title": "zrsa-ove-demo Observatory Demo",
    "version": "0.1.0"
  },
  "servers": {
    "prod": {
      "host": "localhost:8000",
      "protocol": "ws"
    }
  },
  "channels": {
    "arc_width_update": {
      "address": "arc_width_update",
      "messages": {
        "receive": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "arc_width": {
                "title": "Arc Width",
                "type": "number"
              }
            },
            "required": [
              "arc_width"
            ],
            "title": "ArcWidthUpdatePayload",
            "type": "object"
          }
        },
        "send": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "arc_width": {
                "title": "Arc Width",
                "type": "number"
              }
            },
            "required": [
              "arc_width"
            ],
            "title": "ArcWidthUpdatePayload",
            "type": "object"
          }
        }
      }
    },
    "get_state": {
      "address": "get_state",
      "messages": {
        "receive": {},
        "send": {
          "contentType": "application/json",
          "payload": {
            "$defs": {
              "SelectCountyBroadcastPayload": {
                "properties": {
                  "county_id": {
                    "title": "County Id",
                    "type": "string"
                  },
                  "animation_start_time": {
                    "title": "Animation Start Time",
                    "type": "integer"
                  }
                },
                "required": [
                  "county_id",
                  "animation_start_time"
                ],
                "title": "SelectCountyBroadcastPayload",
                "type": "object"
              }
            },
            "description": "Server response for get_state (ack). Matches State.to_dict() shape.",
            "properties": {
              "status": {
                "title": "Status",
                "type": "string"
              },
              "timestamp": {
                "title": "Timestamp",
                "type": "string"
              },
              "text": {
                "title": "Text",
                "type": "string"
              },
              "arc_width": {
                "title": "Arc Width",
                "type": "number"
              },
              "select_county_event": {
                "anyOf": [
                  {
                    "$ref": "#/channels/get_state/messages/send/payload/$defs/SelectCountyBroadcastPayload"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null
              }
            },
            "required": [
              "status",
              "timestamp",
              "text",
              "arc_width"
            ],
            "title": "GetStatePayload",
            "type": "object"
          }
        }
      }
    },
    "reset": {
      "address": "reset",
      "messages": {
        "receive": {},
        "send": {}
      }
    },
    "select_county": {
      "address": "select_county",
      "messages": {
        "receive": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "county_id": {
                "title": "County Id",
                "type": "string"
              }
            },
            "required": [
              "county_id"
            ],
            "title": "SelectCountyPayload",
            "type": "object"
          }
        },
        "send": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "county_id": {
                "title": "County Id",
                "type": "string"
              },
              "animation_start_time": {
                "title": "Animation Start Time",
                "type": "integer"
              }
            },
            "required": [
              "county_id",
              "animation_start_time"
            ],
            "title": "SelectCountyBroadcastPayload",
            "type": "object"
          }
        }
      }
    },
    "start": {
      "address": "start",
      "messages": {
        "receive": {},
        "send": {}
      }
    },
    "stop": {
      "address": "stop",
      "messages": {
        "receive": {},
        "send": {}
      }
    },
    "text_update": {
      "address": "text_update",
      "messages": {
        "receive": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "text": {
                "title": "Text",
                "type": "string"
              }
            },
            "required": [
              "text"
            ],
            "title": "TextUpdatePayload",
            "type": "object"
          }
        },
        "send": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "text": {
                "title": "Text",
                "type": "string"
              }
            },
            "required": [
              "text"
            ],
            "title": "TextUpdatePayload",
            "type": "object"
          }
        }
      }
    },
    "tick": {
      "address": "tick",
      "messages": {
        "send": {
          "contentType": "application/json",
          "payload": {
            "properties": {
              "timestamp": {
                "title": "Timestamp",
                "type": "string"
              }
            },
            "required": [
              "timestamp"
            ],
            "title": "TickPayload",
            "type": "object"
          }
        }
      }
    }
  },
  "operations": {
    "arc_width_update.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/arc_width_update"
      },
      "messages": [
        {
          "$ref": "#/channels/arc_width_update/messages/receive"
        }
      ]
    },
    "arc_width_update.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/arc_width_update"
      },
      "messages": [
        {
          "$ref": "#/channels/arc_width_update/messages/send"
        }
      ]
    },
    "get_state.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/get_state"
      },
      "messages": [
        {
          "$ref": "#/channels/get_state/messages/receive"
        }
      ]
    },
    "get_state.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/get_state"
      },
      "messages": [
        {
          "$ref": "#/channels/get_state/messages/send"
        }
      ],
      "bindings": {
        "x-socketio": {
          "ack": true
        }
      }
    },
    "reset.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/reset"
      },
      "messages": [
        {
          "$ref": "#/channels/reset/messages/receive"
        }
      ]
    },
    "reset.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/reset"
      },
      "messages": [
        {
          "$ref": "#/channels/reset/messages/send"
        }
      ]
    },
    "select_county.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/select_county"
      },
      "messages": [
        {
          "$ref": "#/channels/select_county/messages/receive"
        }
      ]
    },
    "select_county.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/select_county"
      },
      "messages": [
        {
          "$ref": "#/channels/select_county/messages/send"
        }
      ]
    },
    "start.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/start"
      },
      "messages": [
        {
          "$ref": "#/channels/start/messages/receive"
        }
      ]
    },
    "start.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/start"
      },
      "messages": [
        {
          "$ref": "#/channels/start/messages/send"
        }
      ]
    },
    "stop.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/stop"
      },
      "messages": [
        {
          "$ref": "#/channels/stop/messages/receive"
        }
      ]
    },
    "stop.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/stop"
      },
      "messages": [
        {
          "$ref": "#/channels/stop/messages/send"
        }
      ]
    },
    "text_update.receive": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/text_update"
      },
      "messages": [
        {
          "$ref": "#/channels/text_update/messages/receive"
        }
      ]
    },
    "text_update.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/text_update"
      },
      "messages": [
        {
          "$ref": "#/channels/text_update/messages/send"
        }
      ]
    },
    "tick.send": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/tick"
      },
      "messages": [
        {
          "$ref": "#/channels/tick/messages/send"
        }
      ]
    }
  }
}